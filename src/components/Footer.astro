---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p>&copy; {today.getFullYear()} Keemuje. All rights reserved.</p>
		<p class="built-with">Built with <a href="https://astro.build" target="_blank">Astro</a></p>
	</div>
</footer>

<style>
	footer {
		padding: 3rem 1rem;
		border-top: 1px solid var(--border);
		background-color: var(--bg-primary);
		color: var(--text-tertiary);
		text-align: center;
		transition: background-color 0.3s ease, border-color 0.3s ease;
	}

	.footer-content {
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
	}

	p {
		margin: 0;
		font-size: 0.9rem;
	}

	.built-with {
		font-size: 0.85rem;
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}
	
	a:hover {
		text-decoration: underline;
	}
</style>
